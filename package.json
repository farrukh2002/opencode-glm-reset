{
  "name": "@farrukh2002/opencode-glm-reset",
  "version": "1.1.3",
  "description": "OpenCode TUI sidebar plugin for GLM rate limit reset countdown",
  "type": "module",
  "exports": {
    "./tui": "./dist/tui.tsx"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && cp tui.tsx dist/tui.tsx",
    "typecheck": "tsc --noEmit",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "sidebar",
    "glm",
    "reset",
    "countdown"
  ],
  "license": "MIT",
  "engines": {
    "opencode": ">=1.4.3"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.3",
    "@opentui/core": "^0.2.2",
    "@opentui/solid": "^0.2.2",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  }
}
